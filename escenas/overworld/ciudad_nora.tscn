; ─────────────────────────────────────────────────────────────────────────────
; CIUDAD NORA — Ciudad norteña basada en Reynosa
; Layout: 640x520 píxeles de mundo
; Tiene: Hospital Nexo, mercado, varias casas, NPCs de la sierra
; Norte: entrada desde Ruta 1
; Sur: salida futura a Ruta 2
; Usa assets de "Objetos Nora" (temática desierto/western mexicano)
; ─────────────────────────────────────────────────────────────────────────────

[node name="CiudadNora" type="Node2D"]
y_sort_enabled = true
script = ExtResource("1_map")

